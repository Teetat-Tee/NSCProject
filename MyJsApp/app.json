{
  "expo": {
    "name": "OSA Detect",
    "slug": "osa-detect",
    "version": "1.0.0",
    "orientation": "portrait",
    "assetBundlePatterns": [
      "assets/**"
    ],
    "android": {
      "package": "com.tee.osadetect",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-audio",
        {
          "microphonePermission": "อนุญาตให้ OSA Detect เข้าถึงไมโครโฟนเพื่อบันทึกเสียงขณะนอนหลับ",
          "androidAudioForegroundService": {
            "notificationTitle": "OSA Detect กำลังบันทึกเสียง",
            "notificationBody": "แอปกำลังบันทึกเสียงขณะนอนหลับ กรุณาอย่าปิดแอป",
            "notificationColor": "#C0392B"
          }
        }
      ],
      "expo-asset",
      [
        "expo-keep-awake",
        {}
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8efdb8a1-526e-4a4e-a04e-4df0df759424"
      }
    },
    "ios": {
      "bundleIdentifier": "com.tee.osadetect",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["audio"]
      }
    }
  }
}